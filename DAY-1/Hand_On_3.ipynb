      "source": [
        "import numpy as np\n",
        "I= np.eye(3)\n",
        "print(\"Identity: \\n\",I)\n",
        "A= np.array([[2,1],[1,3]])\n",
        "A_inv = np.linalg.inv(A)\n",
        "print(\"A_inv:\\n\",A_inv)\n",
        "print(\"A @ A_inv:\\n\",A @ A_inv)\n"
      ]
    }
  ]
